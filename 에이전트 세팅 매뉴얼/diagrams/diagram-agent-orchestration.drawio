<mxfile host="app.diagrams.net">
  <diagram name="Development Flow" id="dev-flow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Phase 1: 기획 -->
        <mxCell id="phase1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontSize=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="560" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_label" value="1. 기획" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="90" y="35" width="100" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="user" value="👤 사용자" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="main" value="🧠 Main Claude&#xa;(오케스트레이터)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="75" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="planner" value="📋 기획자&#xa;(opus)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="75" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="user" target="main" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="main" target="planner" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PRD -->
        <mxCell id="prd" value="📄 PRD&#xa;(agents-cowork/)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="220" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="planner" target="prd" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Phase 2: 핸드오프 -->
        <mxCell id="phase2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="500" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_label" value="2. 핸드오프 문서 작성" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="130" y="325" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="handoff_be" value="📄 BE 핸드오프" style="shape=document;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="350" width="140" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="handoff_fe" value="📄 FE 핸드오프" style="shape=document;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="350" width="140" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="prd" target="handoff_be" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="prd" target="handoff_fe" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Phase 3: Gemini 개발 -->
        <mxCell id="phase3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f7ff;strokeColor=#4a86c8;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="430" width="500" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_label" value="3. 개발 (Gemini, 독립 세션)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="130" y="435" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="gemini_be" value="🤖 Gemini BE 세션&#xa;백엔드 개발" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="155" y="462" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="gemini_fe" value="🤖 Gemini FE 세션&#xa;프론트엔드 개발" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="415" y="462" width="170" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="handoff_be" target="gemini_be" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="handoff_fe" target="gemini_fe" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Phase 4: 코드 리뷰 -->
        <mxCell id="phase4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f9a825;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="550" width="500" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="phase4_label" value="4. 코드 리뷰 &amp; 보완 (Claude)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="130" y="555" width="260" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="claude_be" value="🔵 Claude BE 에이전트&#xa;(opus)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="155" y="582" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="claude_fe" value="🟢 Claude FE 에이전트&#xa;(sonnet)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="415" y="582" width="170" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="gemini_be" target="claude_be" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="gemini_fe" target="claude_fe" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Phase 5: 통합 리뷰 -->
        <mxCell id="review" value="5. 통합 리뷰&#xa;Main + 사용자" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="670" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="claude_be" target="review" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="claude_fe" target="review" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Phase 6: QA -->
        <mxCell id="qa" value="6. QA" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="760" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="review" target="qa" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- QA 분기: N → 4번으로 루프 -->
        <mxCell id="qa_fail_label" value="N (불합격)" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#cc0000;" vertex="1" parent="1">
          <mxGeometry x="50" y="785" width="90" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="e_qa_fail" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#cc0000;strokeWidth=2;dashed=1;" edge="1" source="qa" target="phase4_bg" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="800"/>
              <mxPoint x="100" y="595"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- QA 분기: Y → 배포 -->
        <mxCell id="qa_pass_label" value="Y (합격)" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#007700;" vertex="1" parent="1">
          <mxGeometry x="380" y="870" width="80" height="20" as="geometry"/>
        </mxCell>

        <!-- Phase 7: 배포 + 문서 정리 (병렬) -->
        <mxCell id="phase7_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="890" width="500" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="phase7_label" value="7. 마무리 (병렬)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="130" y="895" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="deploy" value="🚀 배포 준비" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#67AB9F;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="155" y="922" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="docs" value="📝 문서 정리&#xa;(개발일지, To-Do, 핸드오프)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="922" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e_qa_pass_deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#007700;strokeWidth=2;" edge="1" source="qa" target="deploy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_qa_pass_docs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#007700;strokeWidth=2;" edge="1" source="qa" target="docs" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 완료 -->
        <mxCell id="done" value="✅ 완료" style="shape=ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="1020" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_deploy_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="deploy" target="done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_docs_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="docs" target="done" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
